<Styles
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!--  Hide the column-header strip for tables without a header row (grid tables)  -->
    <Style Selector="TableView.Markdown.Headerless /template/ ScrollViewer /template/ Border#HeaderStrip">
        <Setter Property="IsVisible" Value="False" />
    </Style>
</Styles>
