<ResourceDictionary
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:husk="https://github.com/d3ara1n/Huskui.Avalonia">
    <ControlTheme
        x:Key="{x:Type husk:MarkdownViewer}"
        TargetType="husk:MarkdownViewer">
        <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto" />
        <Setter Property="Template">
            <ControlTemplate>
                <ScrollViewer
                    Name="{x:Static husk:MarkdownViewer.PART_LayoutContainer}"
                    AllowAutoHide="{TemplateBinding ScrollViewer.AllowAutoHide}"
                    HorizontalScrollBarVisibility="{TemplateBinding ScrollViewer.HorizontalScrollBarVisibility}"
                    HorizontalSnapPointsAlignment="{TemplateBinding ScrollViewer.HorizontalSnapPointsAlignment}"
                    HorizontalSnapPointsType="{TemplateBinding ScrollViewer.HorizontalSnapPointsType}"
                    VerticalScrollBarVisibility="{TemplateBinding ScrollViewer.VerticalScrollBarVisibility}"
                    VerticalSnapPointsAlignment="{TemplateBinding ScrollViewer.VerticalSnapPointsAlignment}"
                    VerticalSnapPointsType="{TemplateBinding ScrollViewer.VerticalSnapPointsType}" />
            </ControlTemplate>
        </Setter>
    </ControlTheme>
</ResourceDictionary>
