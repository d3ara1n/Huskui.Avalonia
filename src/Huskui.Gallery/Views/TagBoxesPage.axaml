<controls:ControlPage
    x:Class="Huskui.Gallery.Views.TagBoxesPage"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:Huskui.Gallery.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:husk="https://github.com/d3ara1n/Huskui.Avalonia"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <StackPanel Spacing="32">

        <controls:ExampleContainer
            Title="Basic Tag Selection"
            Description="TagBox combines inline selected tags with searchable suggestions.">
            <controls:ExampleContainer.Controls>
                <StackPanel Spacing="12">
                    <TextBlock
                        FontSize="14"
                        FontWeight="Bold"
                        Text="Selection Helpers" />
                    <Button
                        Click="OnClearBasicClick"
                        Content="Clear Tags" />
                    <Button
                        Click="OnResetBasicClick"
                        Content="Reset Example" />
                    <TextBlock
                        FontSize="12"
                        Foreground="{StaticResource ControlSecondaryForegroundBrush}"
                        Text="Use arrow keys to move through suggestions, then press Enter or Tab to commit the active tag."
                        TextWrapping="Wrap" />
                </StackPanel>
            </controls:ExampleContainer.Controls>

            <StackPanel
                Width="440"
                Spacing="12">
                <TextBlock Text="Technology Stack" />
                <husk:TagBox
                    x:Name="TechnologyTagBox"
                    MinimumPrefixLength="0"
                    PlaceholderText="Add technologies..." />
                <TextBlock
                    x:Name="TechnologySelectionText"
                    FontSize="12"
                    Foreground="{StaticResource ControlSecondaryForegroundBrush}"
                    TextWrapping="Wrap" />
            </StackPanel>
        </controls:ExampleContainer>

        <controls:ExampleContainer
            Title="Custom Tags"
            Description="Enable ad-hoc labels when the suggestion list is not enough for the current workflow.">
            <controls:ExampleContainer.Controls>
                <StackPanel Spacing="12">
                    <TextBlock
                        FontSize="14"
                        FontWeight="Bold"
                        Text="Creation Flow" />
                    <Button
                        Click="OnSeedCustomInputClick"
                        Content="Seed Draft Tag" />
                    <Button
                        Click="OnResetCustomClick"
                        Content="Reset Example" />
                    <TextBlock
                        FontSize="12"
                        Foreground="{StaticResource ControlSecondaryForegroundBrush}"
                        Text="Type a new label and press Enter to create it. Existing suggestions stay deduplicated automatically."
                        TextWrapping="Wrap" />
                </StackPanel>
            </controls:ExampleContainer.Controls>

            <StackPanel
                Width="440"
                Spacing="12">
                <TextBlock Text="Release Labels" />
                <husk:TagBox
                    x:Name="ReleaseTagBox"
                    AllowCustomTags="True"
                    MinimumPrefixLength="0"
                    PlaceholderText="Type a label and press Enter..." />
                <TextBlock
                    x:Name="ReleaseSelectionText"
                    FontSize="12"
                    Foreground="{StaticResource ControlSecondaryForegroundBrush}"
                    TextWrapping="Wrap" />
            </StackPanel>
        </controls:ExampleContainer>

        <controls:ExampleContainer
            Title="Form Example"
            Description="TagBox fits naturally into filtering and assignment forms that need multiple values per field.">
            <husk:Card
                Width="460"
                Padding="24">
                <StackPanel Spacing="20">
                    <TextBlock
                        FontSize="18"
                        FontWeight="Bold"
                        Text="Incident Routing Rules" />

                    <husk:Divider />

                    <StackPanel Spacing="16">
                        <StackPanel Spacing="8">
                            <TextBlock Text="Escalation Teams" />
                            <husk:TagBox
                                x:Name="TeamTagBox"
                                MinimumPrefixLength="0"
                                PlaceholderText="Add responder teams..." />
                        </StackPanel>

                        <StackPanel Spacing="8">
                            <TextBlock Text="Notification Channels" />
                            <husk:TagBox
                                x:Name="ChannelTagBox"
                                MinimumPrefixLength="0"
                                PlaceholderText="Choose delivery channels..." />
                        </StackPanel>

                        <StackPanel Spacing="8">
                            <TextBlock Text="Labels" />
                            <husk:TagBox
                                x:Name="RuleLabelTagBox"
                                AllowCustomTags="True"
                                MinimumPrefixLength="0"
                                PlaceholderText="Add labels for automation..." />
                        </StackPanel>
                    </StackPanel>

                    <TextBlock
                        x:Name="FormSelectionText"
                        FontSize="12"
                        Foreground="{StaticResource ControlSecondaryForegroundBrush}"
                        TextWrapping="Wrap" />

                    <husk:Divider />

                    <StackPanel
                        HorizontalAlignment="Right"
                        Orientation="Horizontal"
                        Spacing="12">
                        <Button
                            Click="OnResetFormClick"
                            Content="Reset" />
                        <Button
                            Classes="Primary"
                            Content="Save Rule" />
                    </StackPanel>
                </StackPanel>
            </husk:Card>
        </controls:ExampleContainer>

    </StackPanel>
</controls:ControlPage>
