<controls:ControlPage
    x:Class="Huskui.Gallery.Views.VariableContainerPage"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:Huskui.Gallery.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:fi="clr-namespace:FluentIcons.Avalonia;assembly=FluentIcons.Avalonia"
    xmlns:husk="https://github.com/d3ara1n/Huskui.Avalonia"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="900"
    d:DesignWidth="900"
    mc:Ignorable="d">

    <StackPanel Spacing="32">

        <controls:ExampleContainer
            Title="Reusable Wrapper Template"
            Description="Template supplies the outer chrome while Content stays in the normal Content slot. VariableContainerPresenter is the reusable placeholder for that content."
            XamlCode="&lt;husk:VariableContainer&gt;&#10;    &lt;husk:VariableContainer.Template&gt;&#10;        &lt;ControlTemplate TargetType=&quot;husk:VariableContainer&quot;&gt;&#10;            &lt;husk:Card Padding=&quot;20&quot;&gt;&#10;                &lt;StackPanel Spacing=&quot;16&quot;&gt;&#10;                    &lt;TextBlock Text=&quot;Template-defined header&quot; /&gt;&#10;                    &lt;husk:VariableContainerPresenter /&gt;&#10;                &lt;/StackPanel&gt;&#10;            &lt;/husk:Card&gt;&#10;        &lt;/ControlTemplate&gt;&#10;    &lt;/husk:VariableContainer.Template&gt;&#10;&#10;    &lt;StackPanel Spacing=&quot;8&quot;&gt;&#10;        &lt;TextBlock Text=&quot;This content is still authored only once.&quot; /&gt;&#10;        &lt;Button Content=&quot;Primary action&quot; /&gt;&#10;    &lt;/StackPanel&gt;&#10;&lt;/husk:VariableContainer&gt;">
            <husk:VariableContainer>
                <husk:VariableContainer.Template>
                    <ControlTemplate TargetType="husk:VariableContainer">
                        <husk:Card Padding="20">
                            <StackPanel Spacing="16">
                                <StackPanel Spacing="4">
                                    <TextBlock
                                        FontSize="{StaticResource LargeFontSize}"
                                        FontWeight="{StaticResource ControlStrongFontWeight}"
                                        Text="Template-defined wrapper" />
                                    <TextBlock
                                        Foreground="{StaticResource ControlSecondaryForegroundBrush}"
                                        Text="The card, header and spacing come from Template. The body below is normal Content."
                                        TextWrapping="Wrap" />
                                </StackPanel>

                                <husk:Divider />

                                <husk:VariableContainerPresenter />
                            </StackPanel>
                        </husk:Card>
                    </ControlTemplate>
                </husk:VariableContainer.Template>

                <StackPanel Spacing="12">
                    <TextBlock
                        Text="This content is still authored only once in VariableContainer.Content."
                        TextWrapping="Wrap" />
                    <WrapPanel
                        ItemSpacing="8"
                        Orientation="Horizontal">
                        <husk:Tag
                            Classes="Primary"
                            Content="Reusable content" />
                        <husk:Tag
                            Classes="Success"
                            Content="Template-bound" />
                    </WrapPanel>
                    <Button
                        Classes="Primary"
                        HorizontalAlignment="Left"
                        Content="Primary action" />
                </StackPanel>
            </husk:VariableContainer>
        </controls:ExampleContainer>

        <controls:ExampleContainer
            Title="SwitchContainer Variants"
            Description="The outer container changes with a value, but the shared content is still declared once. Each shell variant just drops in VariableContainerPresenter."
            XamlCode="&lt;ComboBox x:Name=&quot;ModePicker&quot; SelectedIndex=&quot;0&quot;&gt;&#10;    &lt;ComboBoxItem Content=&quot;Card&quot; /&gt;&#10;    &lt;ComboBoxItem Content=&quot;Outlined&quot; /&gt;&#10;    &lt;ComboBoxItem Content=&quot;Accent&quot; /&gt;&#10;&lt;/ComboBox&gt;&#10;&#10;&lt;husk:VariableContainer&gt;&#10;    &lt;husk:VariableContainer.Template&gt;&#10;        &lt;ControlTemplate TargetType=&quot;husk:VariableContainer&quot;&gt;&#10;            &lt;husk:SwitchContainer Value=&quot;{Binding #ModePicker.SelectedIndex}&quot;&gt;&#10;                &lt;husk:SwitchCase Value=&quot;0&quot;&gt;...&lt;husk:VariableContainerPresenter /&gt;...&lt;/husk:SwitchCase&gt;&#10;                &lt;husk:SwitchCase Value=&quot;1&quot;&gt;...&lt;husk:VariableContainerPresenter /&gt;...&lt;/husk:SwitchCase&gt;&#10;                &lt;husk:SwitchCase Value=&quot;2&quot;&gt;...&lt;husk:VariableContainerPresenter /&gt;...&lt;/husk:SwitchCase&gt;&#10;            &lt;/husk:SwitchContainer&gt;&#10;        &lt;/ControlTemplate&gt;&#10;    &lt;/husk:VariableContainer.Template&gt;&#10;&#10;    &lt;StackPanel Spacing=&quot;12&quot;&gt;...shared content...&lt;/StackPanel&gt;&#10;&lt;/husk:VariableContainer&gt;">
            <controls:ExampleContainer.Controls>
                <StackPanel Spacing="12">
                    <TextBlock
                        FontSize="14"
                        FontWeight="Bold"
                        Text="Container Variant" />
                    <ComboBox
                        x:Name="VariantPicker"
                        SelectedIndex="0">
                        <ComboBoxItem Content="Card" />
                        <ComboBoxItem Content="Outlined" />
                        <ComboBoxItem Content="Accent" />
                    </ComboBox>
                    <TextBlock
                        FontSize="12"
                        Foreground="{StaticResource ControlSecondaryForegroundBrush}"
                        Text="SwitchContainer changes only the wrapper. Each variant contains VariableContainerPresenter, which automatically resolves the shared content from the nearest VariableContainer."
                        TextWrapping="Wrap" />
                </StackPanel>
            </controls:ExampleContainer.Controls>

            <husk:VariableContainer>
                <husk:VariableContainer.Template>
                    <ControlTemplate TargetType="husk:VariableContainer">
                        <husk:SwitchContainer Value="{Binding #VariantPicker.SelectedIndex}">
                            <husk:SwitchCase Value="0">
                                <husk:Card Padding="20">
                                    <StackPanel Spacing="16">
                                        <TextBlock
                                            FontSize="{StaticResource LargeFontSize}"
                                            FontWeight="{StaticResource ControlStrongFontWeight}"
                                            Text="Card variant" />
                                        <husk:VariableContainerPresenter />
                                    </StackPanel>
                                </husk:Card>
                            </husk:SwitchCase>

                            <husk:SwitchCase Value="1">
                                <Border
                                    Padding="20"
                                    Background="{StaticResource ControlBackgroundBrush}"
                                    BorderBrush="{StaticResource ControlBorderBrush}"
                                    BorderThickness="2"
                                    CornerRadius="{StaticResource LargeCornerRadius}">
                                    <StackPanel Spacing="16">
                                        <StackPanel Spacing="4">
                                            <TextBlock
                                                FontSize="{StaticResource LargeFontSize}"
                                                FontWeight="{StaticResource ControlStrongFontWeight}"
                                                Text="Outlined variant" />
                                            <TextBlock
                                                Foreground="{StaticResource ControlSecondaryForegroundBrush}"
                                                Text="Template-defined outline and spacing, same shared inner content."
                                                TextWrapping="Wrap" />
                                        </StackPanel>
                                        <husk:VariableContainerPresenter />
                                    </StackPanel>
                                </Border>
                            </husk:SwitchCase>

                            <husk:SwitchCase Value="2">
                                <Border
                                    Padding="20"
                                    Background="{StaticResource ControlAccentTranslucentFullBackgroundBrush}"
                                    BorderBrush="{StaticResource ControlAccentBorderBrush}"
                                    BorderThickness="1"
                                    CornerRadius="{StaticResource LargeCornerRadius}">
                                    <Grid
                                        ColumnDefinitions="Auto,*"
                                        ColumnSpacing="16">
                                        <Border
                                            Width="44"
                                            Height="44"
                                            Background="{StaticResource ControlAccentBackgroundBrush}"
                                            CornerRadius="22">
                                            <fi:SymbolIcon
                                                HorizontalAlignment="Center"
                                                VerticalAlignment="Center"
                                                Foreground="White"
                                                Symbol="Sparkle" />
                                        </Border>

                                        <StackPanel
                                            Grid.Column="1"
                                            Spacing="16">
                                            <StackPanel Spacing="4">
                                                <TextBlock
                                                    FontSize="{StaticResource LargeFontSize}"
                                                    FontWeight="{StaticResource ControlStrongFontWeight}"
                                                    Text="Accent variant" />
                                                <TextBlock
                                                    Foreground="{StaticResource ControlSecondaryForegroundBrush}"
                                                    Text="Useful when the shell style depends on status, mode, or any external state."
                                                    TextWrapping="Wrap" />
                                            </StackPanel>
                                            <husk:VariableContainerPresenter />
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </husk:SwitchCase>
                        </husk:SwitchContainer>
                    </ControlTemplate>
                </husk:VariableContainer.Template>

                <StackPanel Spacing="14">
                    <Grid
                        ColumnDefinitions="Auto,*"
                        ColumnSpacing="12">
                        <Border
                            Width="56"
                            Height="56"
                            Background="{StaticResource ControlAccentBackgroundBrush}"
                            CornerRadius="28">
                            <TextBlock
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                FontSize="20"
                                FontWeight="Bold"
                                Foreground="White"
                                Text="VC" />
                        </Border>

                        <StackPanel
                            Grid.Column="1"
                            Spacing="2">
                            <TextBlock
                                FontSize="16"
                                FontWeight="{StaticResource ControlStrongFontWeight}"
                                Text="VariableContainer profile content" />
                            <TextBlock
                                Foreground="{StaticResource ControlSecondaryForegroundBrush}"
                                Text="Only this part is authored once, regardless of wrapper variant."
                                TextWrapping="Wrap" />
                        </StackPanel>
                    </Grid>

                    <WrapPanel
                        ItemSpacing="8"
                        Orientation="Horizontal">
                        <husk:Tag Content="Shared content" />
                        <husk:Tag
                            Classes="Primary"
                            Content="SwitchContainer" />
                        <husk:Tag
                            Classes="Success"
                            Content="VariableContainerPresenter" />
                    </WrapPanel>

                    <TextBlock
                        Foreground="{StaticResource ControlSecondaryForegroundBrush}"
                        Text="This pattern is useful for status cards, adaptive shells, or any scenario where the wrapper changes more often than the actual content."
                        TextWrapping="Wrap" />

                    <Button
                        Classes="Primary"
                        HorizontalAlignment="Left"
                        Content="Shared action" />
                </StackPanel>
            </husk:VariableContainer>
        </controls:ExampleContainer>

    </StackPanel>
</controls:ControlPage>
