<controls:ControlPage
    x:Class="Huskui.Gallery.Views.OverlayAppSurfacePage"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:Huskui.Gallery.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:husk="https://github.com/d3ara1n/Huskui.Avalonia"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    d:DesignHeight="900"
    d:DesignWidth="900"
    mc:Ignorable="d">

    <StackPanel Spacing="32">
        <controls:ExampleContainer
            Title="AppSurface overlay root"
            Description="How desktop, browser, and mobile shells should host AppSurface so dialogs, modals, toasts, drawers, sidebars, and growls can appear correctly.">
            <husk:MarkdownViewer x:Name="Viewer" />
        </controls:ExampleContainer>
    </StackPanel>
</controls:ControlPage>
