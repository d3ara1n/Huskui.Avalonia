<controls:ControlPage
    x:Class="Huskui.Gallery.Views.MvvmPage"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:Huskui.Gallery.Controls"
    xmlns:fi="clr-namespace:FluentIcons.Avalonia;assembly=FluentIcons.Avalonia"
    xmlns:husk="https://github.com/d3ara1n/Huskui.Avalonia">
    <StackPanel Spacing="32">

        <Border
            Padding="24"
            Background="{StaticResource CardBackgroundBrush}"
            BorderBrush="{StaticResource ControlBorderBrush}"
            BorderThickness="1"
            CornerRadius="{StaticResource MediumCornerRadius}">
            <StackPanel Spacing="16">
                <TextBlock
                    FontSize="{StaticResource LargeFontSize}"
                    FontWeight="{StaticResource ControlStrongFontWeight}"
                    Text="A lightweight MVVM integration layer for Huskui-based apps" />
                <TextBlock
                    Foreground="{StaticResource ControlSecondaryForegroundBrush}"
                    Text="Huskui.Avalonia.Mvvm focuses on the glue code that tends to get rewritten in every Avalonia application: view activation, ViewModel lifecycle binding, parameter passing, and page-level state restoration."
                    TextWrapping="Wrap" />
                <husk:InfoBar Header="Read the README for full usage details">
                    <TextBlock TextWrapping="Wrap">
                        This page is only an overview. The package README contains the full API surface, registration patterns, examples, and behavior notes.
                    </TextBlock>
                </husk:InfoBar>
                <WrapPanel
                    ItemSpacing="8"
                    LineSpacing="8"
                    Orientation="Horizontal">
                    <HyperlinkButton
                        NavigateUri="https://github.com/d3ara1n/Huskui.Avalonia/blob/main/src/Huskui.Avalonia.Mvvm/README.md"
                        Theme="{StaticResource AccentButtonTheme}">
                        <StackPanel
                            Orientation="Horizontal"
                            Spacing="8">
                            <fi:SymbolIcon
                                FontSize="{StaticResource MediumFontSize}"
                                Symbol="Document" />
                            <TextBlock Text="Open README" />
                        </StackPanel>
                    </HyperlinkButton>
                </WrapPanel>
            </StackPanel>
        </Border>

        <Grid
            ColumnDefinitions="*,*"
            ColumnSpacing="24"
            RowDefinitions="Auto,Auto"
            RowSpacing="24">
            <Border
                Grid.Row="0"
                Grid.Column="0"
                Padding="24"
                Background="{StaticResource CardBackgroundBrush}"
                BorderBrush="{StaticResource ControlBorderBrush}"
                BorderThickness="1"
                CornerRadius="{StaticResource MediumCornerRadius}">
                <StackPanel Spacing="12">
                    <fi:SymbolIcon
                        FontSize="24"
                        Foreground="{StaticResource ControlAccentForegroundBrush}"
                        Symbol="ArrowSync" />
                    <TextBlock
                        FontSize="{StaticResource LargeFontSize}"
                        FontWeight="{StaticResource ControlStrongFontWeight}"
                        Text="Lifecycle Binding" />
                    <TextBlock
                        Foreground="{StaticResource ControlSecondaryForegroundBrush}"
                        Text="Binds control load and unload events to ViewModel initialization and cleanup, so async setup and teardown stop living in ad-hoc page code-behind."
                        TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <Border
                Grid.Row="0"
                Grid.Column="1"
                Padding="24"
                Background="{StaticResource CardBackgroundBrush}"
                BorderBrush="{StaticResource ControlBorderBrush}"
                BorderThickness="1"
                CornerRadius="{StaticResource MediumCornerRadius}">
                <StackPanel Spacing="12">
                    <fi:SymbolIcon
                        FontSize="24"
                        Foreground="{StaticResource ControlAccentForegroundBrush}"
                        Symbol="Navigation" />
                    <TextBlock
                        FontSize="{StaticResource LargeFontSize}"
                        FontWeight="{StaticResource ControlStrongFontWeight}"
                        Text="View Activation" />
                    <TextBlock
                        Foreground="{StaticResource ControlSecondaryForegroundBrush}"
                        Text="Provides a reusable activation path for Frame-based navigation: create the view, resolve the ViewModel from DI, pass navigation data, and attach the MVVM mixins in one place."
                        TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <Border
                Grid.Row="1"
                Grid.Column="0"
                Padding="24"
                Background="{StaticResource CardBackgroundBrush}"
                BorderBrush="{StaticResource ControlBorderBrush}"
                BorderThickness="1"
                CornerRadius="{StaticResource MediumCornerRadius}">
                <StackPanel Spacing="12">
                    <fi:SymbolIcon
                        FontSize="24"
                        Foreground="{StaticResource ControlAccentForegroundBrush}"
                        Symbol="BranchFork" />
                    <TextBlock
                        FontSize="{StaticResource LargeFontSize}"
                        FontWeight="{StaticResource ControlStrongFontWeight}"
                        Text="State Restoration" />
                    <TextBlock
                        Foreground="{StaticResource ControlSecondaryForegroundBrush}"
                        Text="Adds a small state model for page-scoped UI state such as selected tabs, filters, search input, and temporary workflow progress, with optional persistence behind it."
                        TextWrapping="Wrap" />
                </StackPanel>
            </Border>

            <Border
                Grid.Row="1"
                Grid.Column="1"
                Padding="24"
                Background="{StaticResource CardBackgroundBrush}"
                BorderBrush="{StaticResource ControlBorderBrush}"
                BorderThickness="1"
                CornerRadius="{StaticResource MediumCornerRadius}">
                <StackPanel Spacing="12">
                    <fi:SymbolIcon
                        FontSize="24"
                        Foreground="{StaticResource ControlAccentForegroundBrush}"
                        Symbol="PuzzlePiece" />
                    <TextBlock
                        FontSize="{StaticResource LargeFontSize}"
                        FontWeight="{StaticResource ControlStrongFontWeight}"
                        Text="What Problem It Solves" />
                    <TextBlock
                        Foreground="{StaticResource ControlSecondaryForegroundBrush}"
                        Text="It removes repetitive MVVM plumbing from application code and turns it into explicit extension points, making navigation, lifecycle, and state behavior easier to standardize across a project."
                        TextWrapping="Wrap" />
                </StackPanel>
            </Border>
        </Grid>

    </StackPanel>
</controls:ControlPage>
