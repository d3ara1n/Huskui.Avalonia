<controls:ControlPage
    x:Class="Huskui.Gallery.Views.ModalActionPanelsPage"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:Huskui.Gallery.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:husk="https://github.com/d3ara1n/Huskui.Avalonia"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:views="clr-namespace:Huskui.Gallery.Views"
    d:DesignHeight="800"
    d:DesignWidth="900"
    mc:Ignorable="d">
    <StackPanel Spacing="32">

        <!-- 1. Interactive: Layout x PrimaryPlacement matrix -->
        <controls:ExampleContainer
            Title="Interactive — Layout and PrimaryPlacement"
            Description="Layout aligns the button group (pure layout, no platform awareness). PrimaryPlacement decides whether the IsDefault primary sits first (Leading) or last (Trailing) in the sequence — this is the only platform-aware part. Auto follows the running platform (macOS=Trailing, others=Leading). Try each Layout: every one now reflects the platform-correct ordering.">
            <controls:ExampleContainer.Controls>
                <StackPanel Spacing="12">
                    <TextBlock
                        FontSize="14"
                        FontWeight="Bold"
                        Text="Controls" />

                    <StackPanel Spacing="4">
                        <TextBlock
                            FontSize="12"
                            Foreground="{StaticResource ControlSecondaryForegroundBrush}"
                            Text="Layout" />
                        <ComboBox
                            HorizontalAlignment="Stretch"
                            ItemsSource="{Binding $parent[views:ModalActionPanelsPage].LayoutOptions}"
                            SelectedItem="{Binding #DemoPanel.Layout, Mode=TwoWay}" />
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <TextBlock
                            FontSize="12"
                            Foreground="{StaticResource ControlSecondaryForegroundBrush}"
                            Text="PrimaryPlacement" />
                        <ComboBox
                            HorizontalAlignment="Stretch"
                            ItemsSource="{Binding $parent[views:ModalActionPanelsPage].PrimaryPlacementOptions}"
                            SelectedItem="{Binding #DemoPanel.PrimaryPlacement, Mode=TwoWay}" />
                    </StackPanel>

                    <StackPanel Spacing="4">
                        <TextBlock
                            FontSize="12"
                            Foreground="{StaticResource ControlSecondaryForegroundBrush}"
                            Text="Spacing" />
                        <Slider
                            x:Name="SpacingSlider"
                            IsSnapToTickEnabled="True"
                            Maximum="24"
                            Minimum="0"
                            TickFrequency="2"
                            Value="8" />
                    </StackPanel>

                    <CheckBox
                        x:Name="ShowPrimary"
                        Content="Show primary (IsDefault)"
                        IsChecked="True" />

                    <TextBlock
                        FontSize="12"
                        Foreground="{StaticResource ControlSecondaryForegroundBrush}"
                        Text="Tip: set PrimaryPlacement to Leading/Trailing to compare sides without switching platforms."
                        TextWrapping="Wrap" />
                </StackPanel>
            </controls:ExampleContainer.Controls>

            <Border
                Width="520"
                Padding="16"
                HorizontalAlignment="Center"
                Background="{StaticResource FlyoutBackgroundBrush}"
                BorderBrush="{StaticResource ControlInteractiveBorderBrush}"
                BorderThickness="1"
                CornerRadius="{StaticResource MediumCornerRadius}">
                <husk:ModalActionPanel
                    x:Name="DemoPanel"
                    Layout="Stretch"
                    Spacing="{Binding #SpacingSlider.Value}">
                    <Button
                        Classes="Primary"
                        Content="Confirm"
                        IsDefault="True"
                        IsVisible="{Binding #ShowPrimary.IsChecked}" />
                    <Button
                        Content="Cancel"
                        IsCancel="True" />
                </husk:ModalActionPanel>
            </Border>
        </controls:ExampleContainer>

        <!-- 2. Dialog footer (Stretch) -->
        <controls:ExampleContainer
            Title="Dialog Footer — Stretch"
            Description="The Dialog theme uses Stretch: children split the width evenly, primary ordered per platform. macOS: [Cancel | Confirm]; others: [Confirm | Cancel].">
            <Border
                Width="520"
                Padding="16"
                HorizontalAlignment="Center"
                Background="{StaticResource FlyoutBackgroundBrush}"
                BorderBrush="{StaticResource ControlInteractiveBorderBrush}"
                BorderThickness="1"
                CornerRadius="{StaticResource MediumCornerRadius}">
                <husk:ModalActionPanel
                    Layout="Stretch"
                    Spacing="8">
                    <Button
                        Classes="Primary"
                        Content="Confirm"
                        IsDefault="True" />
                    <Button
                        Content="Cancel"
                        IsCancel="True" />
                </husk:ModalActionPanel>
            </Border>
        </controls:ExampleContainer>

        <!-- 3. Multi-action Edge -->
        <controls:ExampleContainer
            Title="Multi-action — Edge with three buttons"
            Description="Edge hugs the whole group to the primary's side. Non-IsDefault children stay together in document order. Save (IsDefault) leads the group; the two secondary actions follow.">
            <Border
                Width="520"
                Padding="16"
                HorizontalAlignment="Center"
                Background="{StaticResource FlyoutBackgroundBrush}"
                BorderBrush="{StaticResource ControlInteractiveBorderBrush}"
                BorderThickness="1"
                CornerRadius="{StaticResource MediumCornerRadius}">
                <husk:ModalActionPanel
                    Layout="Edge"
                    Spacing="8">
                    <Button
                        Classes="Primary"
                        Content="Save"
                        IsDefault="True" />
                    <Button Content="Don't Save" />
                    <Button
                        Content="Cancel"
                        IsCancel="True" />
                </husk:ModalActionPanel>
            </Border>
        </controls:ExampleContainer>

    </StackPanel>

</controls:ControlPage>
