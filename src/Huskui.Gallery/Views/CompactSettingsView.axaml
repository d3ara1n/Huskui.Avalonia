<UserControl
    x:Class="Huskui.Gallery.Views.CompactSettingsView"
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:Huskui.Gallery.Controls"
    xmlns:services="clr-namespace:Huskui.Gallery.Services"
    x:DataType="services:IThemeService">
    <controls:ThemeSelector
        ShowBackgroundSelector="False"
        ThemeService="{Binding}" />
</UserControl>
