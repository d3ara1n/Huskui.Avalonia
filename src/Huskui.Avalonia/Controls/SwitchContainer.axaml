<ResourceDictionary
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="https://github.com/d3ara1n/Huskui.Avalonia">
    <Design.PreviewWith>
        <Panel Background="White">
            <local:SwitchContainer
                Margin="24"
                TargetType="x:Int32"
                Value="2">
                <local:SwitchCase Value="1">1</local:SwitchCase>
                <local:SwitchCase Value="2">222</local:SwitchCase>
                <local:SwitchCase Value="3">3</local:SwitchCase>
            </local:SwitchContainer>
        </Panel>
    </Design.PreviewWith>
    <ControlTheme
        x:Key="{x:Type local:SwitchContainer}"
        TargetType="local:SwitchContainer">
        <Setter Property="Template">
            <ControlTemplate>
                <ContentPresenter Content="{TemplateBinding Content}" />
            </ControlTemplate>
        </Setter>
    </ControlTheme>
</ResourceDictionary>
