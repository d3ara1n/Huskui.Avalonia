<ResourceDictionary
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="https://github.com/d3ara1n/Huskui.Avalonia">

    <ControlTheme x:Key="{x:Type local:NavMenu}" TargetType="local:NavMenu">
        <Setter Property="CollapseWidth" Value="72" />
        <Setter Property="ExpandWidth" Value="320" />

        <Setter Property="Template">
            <ControlTemplate TargetType="local:NavMenu">
                <Border
                    Name="PART_RootBorder"
                    Background="{StaticResource LayerBackgroundBrush}"
                    BorderBrush="{StaticResource ControlBorderBrush}"
                    BorderThickness="0,0,1,0">
                    <Border.Transitions>
                        <Transitions>
                            <DoubleTransition
                                Property="Width"
                                Duration="{StaticResource ControlFasterAnimationDuration}"
                                Easing="CubicEaseInOut" />
                        </Transitions>
                    </Border.Transitions>
                    <Grid RowDefinitions="Auto, *, Auto">

                        <ContentPresenter Content="{TemplateBinding HeaderTemplate}" />

                        <ScrollViewer
                            Grid.Row="1"
                            HorizontalAlignment="Stretch"
                            HorizontalScrollBarVisibility="Disabled"
                            AllowAutoHide="True"
                            VerticalScrollBarVisibility="Auto">
                            <ScrollViewer.Styles>
                                <Style Selector="ScrollViewer /template/ ScrollBar">
                                    <Setter Property="Opacity" Value="0" />
                                </Style>
                                <Style Selector="ScrollViewer:pointerover">
                                    <Style Selector="^ /template/ ScrollBar#PART_HorizontalScrollBar">
                                        <Setter Property="Opacity" Value="1" />
                                    </Style>
                                    <Style Selector="^ /template/ ScrollBar#PART_VerticalScrollBar">
                                        <Setter Property="Opacity" Value="1" />
                                    </Style>
                                </Style>
                            </ScrollViewer.Styles>
                            <ItemsPresenter
                                Name="PART_ItemsPresenter"
                                Margin="0,4"
                                KeyboardNavigation.TabNavigation="Continue" />
                        </ScrollViewer>

                        <ContentPresenter Grid.Row="2" Content="{TemplateBinding Footer}" />
                    </Grid>
                </Border>
            </ControlTemplate>
        </Setter>

        <Style Selector="^:not(:horizontal-collapsed) /template/ Border#PART_RootBorder">
            <Setter Property="Width" Value="{Binding ExpandWidth, RelativeSource={RelativeSource TemplatedParent}}" />
        </Style>

        <Style Selector="^:horizontal-collapsed">
            <Style Selector="^ /template/ Border#PART_RootBorder">
                <Setter Property="Width" Value="{Binding CollapseWidth, RelativeSource={RelativeSource TemplatedParent}}" />
            </Style>
            <Style Selector="^ /template/ ScrollViewer">
                <Setter Property="VerticalScrollBarVisibility" Value="Hidden" />
            </Style>
        </Style>
    </ControlTheme>

    <ControlTheme x:Key="{x:Type local:NavMenuItem}" TargetType="local:NavMenuItem">
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Background" Value="{StaticResource ControlTranslucentHalfBackgroundBrush}" />
        <Setter Property="Foreground" Value="{StaticResource ControlForegroundBrush}" />
        <Setter Property="CornerRadius" Value="{StaticResource SmallCornerRadius}" />
        <Setter Property="BorderBrush" Value="{StaticResource ControlBorderBrush}" />
        <Setter Property="BorderThickness" Value="1" />
        <Setter Property="ClipToBounds" Value="False" />
        <Setter Property="Padding" Value="12,8" />
        <Setter Property="Focusable" Value="True" />
        <Setter Property="Margin" Value="6,2" />
        <Setter Property="IconTemplate">
            <DataTemplate x:DataType="{x:Type x:Object}">
                <PathIcon
                    Width="24"
                    Height="24"
                    Data="{ReflectionBinding}" />
            </DataTemplate>
        </Setter>
        <Setter Property="ContentTemplate">
            <DataTemplate x:DataType="{x:Type x:Object}">
                <TextBlock
                    FontSize="{StaticResource LargeFontSize}"
                    FontWeight="{StaticResource ControlStrongFontWeight}"
                    Text="{ReflectionBinding}" />
            </DataTemplate>
        </Setter>

        <Setter Property="Template">
            <ControlTemplate>
                <Panel>
                    <Border
                        x:Name="Background"
                        Margin="{TemplateBinding Margin}"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="{TemplateBinding CornerRadius}"
                        ToolTip.Tip="{TemplateBinding Description}">
                        <Border.Transitions>
                            <Transitions>
                                <BrushTransition
                                    Easing="SineEaseInOut"
                                    Property="Background"
                                    Duration="{StaticResource ControlFasterAnimationDuration}" />
                                <BrushTransition
                                    Easing="SineEaseInOut"
                                    Property="BorderBrush"
                                    Duration="{StaticResource ControlFasterAnimationDuration}" />
                            </Transitions>
                        </Border.Transitions>
                    </Border>
                    <Border
                        Name="Indicator"
                        Width="3"
                        Margin="0,4"
                        HorizontalAlignment="Left"
                        Background="{StaticResource ControlAccentInteractiveBackgroundBrush}"
                        BorderBrush="{StaticResource ControlAccentTranslucentFullBackgroundBrush}"
                        BorderThickness="1"
                        CornerRadius="{StaticResource SmallCornerRadius}"
                        Opacity="0"
                        RenderTransform="translateX(-4px)">
                        <Border.Transitions>
                            <Transitions>
                                <DoubleTransition
                                    Easing="SineEaseOut"
                                    Property="Opacity"
                                    Duration="{StaticResource ControlFasterAnimationDuration}" />
                                <TransformOperationsTransition
                                    Easing="SineEaseOut"
                                    Property="RenderTransform"
                                    Duration="{StaticResource ControlFasterAnimationDuration}" />
                            </Transitions>
                        </Border.Transitions>
                    </Border>
                    <Border Padding="{TemplateBinding Padding}">
                        <Grid
                            Cursor="{TemplateBinding Cursor}"
                            ColumnDefinitions="Auto,*">
                            <ContentPresenter
                                Name="PART_IconPresenter"
                                Grid.Column="0"
                                Margin="12,0"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Center"
                                Content="{Binding Icon, RelativeSource={RelativeSource TemplatedParent}}"
                                ContentTemplate="{Binding IconTemplate, RelativeSource={RelativeSource TemplatedParent}}">
                                <ContentPresenter.Transitions>
                                    <Transitions>
                                        <ThicknessTransition Property="Margin" Duration="0.2" Easing="CubicEaseInOut" />
                                    </Transitions>
                                </ContentPresenter.Transitions>
                            </ContentPresenter>
                            <ContentPresenter
                                Name="PART_ContentPresenter"
                                Grid.Column="1"
                                Margin="4"
                                Content="{Binding Content, RelativeSource={RelativeSource TemplatedParent}}"
                                ContentTemplate="{Binding ContentTemplate, RelativeSource={RelativeSource TemplatedParent}}">
                            </ContentPresenter>
                        </Grid>
                    </Border>
                </Panel>
            </ControlTemplate>
        </Setter>

        <Style Selector="^:pointerover:not(:selected) /template/ Border#Background">
            <Setter Property="Background" Value="{StaticResource ControlAccentTranslucentHalfBackgroundBrush}" />
            <Setter Property="BorderBrush" Value="{StaticResource ControlAccentInteractiveBorderBrush}" />
        </Style>

        <Style Selector="^:selected">
            <Style Selector="^ /template/ Border#Background">
                <Setter Property="Background" Value="{StaticResource ControlAccentTranslucentFullBackgroundBrush}" />
                <Setter Property="BorderBrush" Value="{StaticResource ControlAccentInteractiveBorderBrush}" />
            </Style>
            <Style Selector="^ /template/ Border#Indicator">
                <Setter Property="Opacity" Value="1" />
                <Setter Property="RenderTransform" Value="translateX(0px)" />
            </Style>
        </Style>

        <Style Selector="^:horizontal-collapsed">

            <Style Selector="^:horizontal-collapsed:not(:pointerover):not(:selected) /template/ Border#Background">
                <Setter Property="Opacity" Value="0" />
            </Style>

            <Style Selector="^:horizontal-collapsed /template/ Border#Background">
                <Setter Property="Margin" Value="0,2" />
                <Setter Property="BorderBrush" Value="Transparent" />
                <Setter Property="BorderThickness" Value="0" />
            </Style>

            <Style Selector="^ /template/ ContentPresenter#PART_IconPresenter">
                <Setter Property="Grid.ColumnSpan" Value="3" />
                <Setter Property="Margin" Value="0" />
            </Style>

            <Style Selector="^ /template/ ContentPresenter#PART_ContentPresenter">
                <Setter Property="Opacity" Value="0" />
            </Style>

            <Setter Property="(ToolTip.Tip)">
                <Binding Path="Content" RelativeSource="{RelativeSource AncestorType=local:NavMenuItem}" />
            </Setter>
            <Setter Property="(ToolTip.ShowDelay)" Value="100" />
        </Style>

        <Style Selector="^[IsSeparator=True]">
            <Setter Property="Focusable" Value="False" />
            <Setter Property="Cursor" Value="Arrow" />
            <Setter Property="Template">
                <ControlTemplate>
                    <TextBlock
                        Text="{TemplateBinding Title}" />
                </ControlTemplate>
            </Setter>

            <Style Selector="^:horizontal-collapsed">
                <Setter Property="IsVisible" Value="False" />
            </Style>
            <Style Selector="^ TextBlock">
                <Setter Property="FontWeight" Value="{StaticResource ControlStrongFontWeight}" />
                <Setter Property="FontSize" Value="{StaticResource MediumFontSize}" />
                <Setter Property="Foreground" Value="{StaticResource ControlSecondaryForegroundBrush}" />
                <Setter Property="Margin" Value="12,16,12,8" />
            </Style>
        </Style>
    </ControlTheme>
</ResourceDictionary>
