<ResourceDictionary
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <DynamicResource
        x:Key="ExtraSmallCornerRadius"
        ResourceKey="StaticExtraSmallCornerRadius" />
    <DynamicResource
        x:Key="SmallCornerRadius"
        ResourceKey="StaticSmallCornerRadius" />
    <DynamicResource
        x:Key="MediumCornerRadius"
        ResourceKey="StaticMediumCornerRadius" />
    <DynamicResource
        x:Key="LargeCornerRadius"
        ResourceKey="StaticLargeCornerRadius" />
    <DynamicResource
        x:Key="ExtraLargeCornerRadius"
        ResourceKey="StaticExtraLargeCornerRadius" />
    <DynamicResource
        x:Key="ExtraExtraLargeCornerRadius"
        ResourceKey="StaticExtraExtraLargeCornerRadius" />
    <DynamicResource
        x:Key="ExtraExtraExtraLargeCornerRadius"
        ResourceKey="StaticExtraExtraExtraLargeCornerRadius" />
    <DynamicResource
        x:Key="FullCornerRadius"
        ResourceKey="StaticFullCornerRadius" />
</ResourceDictionary>
