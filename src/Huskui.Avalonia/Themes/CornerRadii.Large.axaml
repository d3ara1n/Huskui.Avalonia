<ResourceDictionary
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <CornerRadius x:Key="StaticExtraSmallCornerRadius">4</CornerRadius>
    <CornerRadius x:Key="StaticSmallCornerRadius">8</CornerRadius>
    <CornerRadius x:Key="StaticMediumCornerRadius">12</CornerRadius>
    <CornerRadius x:Key="StaticLargeCornerRadius">16</CornerRadius>
    <CornerRadius x:Key="StaticExtraLargeCornerRadius">20</CornerRadius>
    <CornerRadius x:Key="StaticExtraExtraLargeCornerRadius">26</CornerRadius>
    <CornerRadius x:Key="StaticExtraExtraExtraLargeCornerRadius">32</CornerRadius>
    <CornerRadius x:Key="StaticFullCornerRadius">999</CornerRadius>
</ResourceDictionary>
