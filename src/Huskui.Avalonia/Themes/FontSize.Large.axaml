<ResourceDictionary
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:sys="using:System">
    <sys:Double x:Key="ExtraSmallFontSize">9</sys:Double>
    <sys:Double x:Key="SmallFontSize">11</sys:Double>
    <sys:Double x:Key="MediumFontSize">13</sys:Double>
    <sys:Double x:Key="LargeFontSize">17</sys:Double>
    <sys:Double x:Key="ExtraLargeFontSize">25</sys:Double>
    <sys:Double x:Key="ExtraExtraLargeFontSize">33</sys:Double>
    <sys:Double x:Key="ExtraExtraExtraLargeFontSize">49</sys:Double>
    <sys:Double x:Key="ExtraExtraExtraExtraLargeFontSize">65</sys:Double>
</ResourceDictionary>
