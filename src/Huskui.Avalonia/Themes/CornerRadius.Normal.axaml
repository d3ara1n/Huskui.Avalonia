<ResourceDictionary
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <CornerRadius x:Key="StaticExtraSmallCornerRadius">1</CornerRadius>
    <CornerRadius x:Key="StaticSmallCornerRadius">3</CornerRadius>
    <CornerRadius x:Key="StaticMediumCornerRadius">6</CornerRadius>
    <CornerRadius x:Key="StaticLargeCornerRadius">9</CornerRadius>
    <CornerRadius x:Key="StaticExtraLargeCornerRadius">14</CornerRadius>
    <CornerRadius x:Key="StaticExtraExtraLargeCornerRadius">20</CornerRadius>
    <CornerRadius x:Key="StaticExtraExtraExtraLargeCornerRadius">28</CornerRadius>
    <CornerRadius x:Key="StaticFullCornerRadius">999</CornerRadius>
</ResourceDictionary>
